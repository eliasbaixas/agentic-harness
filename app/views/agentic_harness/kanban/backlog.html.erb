<% content_for :title, "Feature Backlog" %>
<% content_for :head do %>
  <style>
    .doc-prose { color: #1f2937; line-height: 1.75; }
    .doc-prose h1,.doc-prose h2,.doc-prose h3,.doc-prose h4 { font-weight: 700; line-height: 1.3; margin-top: 1.75em; margin-bottom: 0.5em; color: #111827; }
    .doc-prose h1 { font-size: 1.75rem; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.4em; margin-top: 0; }
    .doc-prose h2 { font-size: 1.25rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.3em; }
    .doc-prose h3 { font-size: 1.05rem; }
    .doc-prose p  { margin: 0.85em 0; }
    .doc-prose ul,.doc-prose ol { padding-left: 1.5em; margin: 0.75em 0; }
    .doc-prose li { margin: 0.3em 0; }
    .doc-prose ul li { list-style-type: disc; }
    .doc-prose ol li { list-style-type: decimal; }
    .doc-prose a  { color: #4f46e5; text-decoration: underline; }
    .doc-prose a:hover { color: #3730a3; }
    .doc-prose code { background: #f3f4f6; border-radius: 0.25rem; padding: 0.1em 0.35em; font-size: 0.85em; font-family: ui-monospace, monospace; color: #374151; }
    .doc-prose pre  { background: #1f2937; color: #f9fafb; border-radius: 0.5rem; padding: 1rem 1.25rem; overflow-x: auto; margin: 1em 0; }
    .doc-prose pre code { background: transparent; color: inherit; padding: 0; font-size: 0.875rem; }
    .doc-prose blockquote { border-left: 4px solid #e5e7eb; padding-left: 1em; color: #6b7280; margin: 1em 0; font-style: italic; }
    .doc-prose table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin: 1em 0; }
    .doc-prose th,.doc-prose td { border: 1px solid #e5e7eb; padding: 0.5em 0.75em; text-align: left; }
    .doc-prose th { background: #f9fafb; font-weight: 600; }
    .doc-prose hr { border: none; border-top: 1px solid #e5e7eb; margin: 2em 0; }
    .doc-prose input[type=checkbox] { margin-right: 0.35em; }
  </style>
<% end %>

<div class="max-w-5xl mx-auto px-4 py-8">

  <%# Breadcrumb %>
  <nav class="flex items-center gap-1.5 text-sm text-gray-400 dark:text-gray-500 mb-6">
    <%= link_to "Kanban", kanban_path, class: "hover:text-gray-700 dark:hover:text-gray-300" %>
    <span>/</span>
    <span class="text-gray-700 dark:text-gray-200 font-medium">Backlog</span>
  </nav>

  <article class="doc-prose">
    <%= @backlog.rendered_html %>
  </article>

</div>
